# ez-appsec Test Environment Configuration
# This file contains configuration for live testing of ez-appsec

# Test Platform Configuration
TEST_PLATFORM=both  # Options: gitlab, github, both

# GitLab Test Configuration
GITLAB_TEST_GROUP=
GITLAB_TEST_URL=https://gitlab.com
GITLAB_TEST_TOKEN=  # Add your GitLab personal access token (read_api, api scopes)

# GitHub Test Configuration
GITHUB_TEST_ORG=
GITHUB_TEST_URL=https://github.com
GITHUB_TEST_TOKEN=  # Add your GitHub personal access token (repo, security_events scopes)

# Test Repository URLs (public)
JUICE_SHOP_REPO=https://github.com/juice-shop/juice-shop
DVWA_REPO=https://github.com/digininja/DVWA
WEBGOAT_REPO=https://github.com/WebGoat/WebGoat
BWAPP_REPO=https://github.com/raesene/bWAPP

# Local Test Paths
TEST_BASE_DIR=./tests/live
FIXTURES_DIR=./tests/live/fixtures
RESULTS_DIR=./tests/live/results

# Test Scanning Configuration
TEST_SCAN_TIMEOUT=300  # 5 minutes per scan
TEST_MAX_CONCURRENT_SCANS=3

# Output Configuration
TEST_OUTPUT_FORMAT=json  # Options: json, sarif, gitlab, all
TEST_VERBOSE=false

# Docker Configuration
DOCKER_NETWORK=ez-appsec-test-net
JUICE_SHOP_PORT=3000
DVWA_PORT=8080

# Dashboard Configuration
TEST_DASHBOARD_URL=  # URL of test dashboard if hosted separately
TEST_DASHBOARD_TOKEN=  # Token for dashboard API access

# CI/CD Configuration
TEST_CI_PIPELINE_BRANCH=main
TEST_CI_TRIGGER_ON=push  # Options: push, schedule, manual

# Reporting Configuration
TEST_RESULTS_FILE=tests/live/results/test-results.json
TEST_ACCURACY_THRESHOLD=70  # Minimum detection accuracy (%)

# Optional: Override these for specific test runs
# SKIP_DOCKER_TESTS=true  # Skip Docker-based tests
# SKIP_GITLAB_TESTS=true  # Skip GitLab integration tests
# SKIP_GITHUB_TESTS=true  # Skip GitHub integration tests
# SKIP_DASHBOARD_TESTS=true  # Skip dashboard validation tests

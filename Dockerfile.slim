# Ultra-lightweight variant using distroless base
# Build: docker build -f Dockerfile.slim -t ez-appsec:slim .
# Size target: ~250-300MB

FROM python:3.11-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    git gcc musl-dev && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app
WORKDIR /app
RUN pip install --no-cache-dir -e .


FROM python:3.11-slim

# Install only runtime essentials
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install gitleaks
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then \
        curl -fsSL https://github.com/gitleaks/gitleaks/releases/download/v8.18.0/gitleaks-linux-arm64 -o /usr/local/bin/gitleaks; \
    else \
        curl -fsSL https://github.com/gitleaks/gitleaks/releases/download/v8.18.0/gitleaks-linux-amd64 -o /usr/local/bin/gitleaks; \
    fi && \
    chmod +x /usr/local/bin/gitleaks && \
    gitleaks version

# Install grype
RUN curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b /usr/local/bin && \
    grype version

# Install semgrep
RUN pip install --no-cache-dir semgrep && \
    semgrep --version

# Install kics
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then \
        curl -fsSL https://github.com/Checkmarx/kics/releases/download/v1.6.12/kics-linux-arm64 -o /usr/local/bin/kics; \
    else \
        curl -fsSL https://github.com/Checkmarx/kics/releases/download/v1.6.12/kics-linux-amd64 -o /usr/local/bin/kics; \
    fi && \
    chmod +x /usr/local/bin/kics && \
    kics version

COPY --from=builder /opt/venv /opt/venv

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /scan

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s \
    CMD ez-appsec --version || exit 1

ENTRYPOINT ["ez-appsec"]
CMD ["--help"]

{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ez-appsec",
          "version": "0.1.17",
          "informationUri": "https://github.com/ez-appsec/ez-appsec",
          "rules": [
            {
              "id": "aws-access-key",
              "name": "AWS Access Key",
              "shortDescription": {
                "text": "AWS access key exposed in code"
              }
            },
            {
              "id": "sql-injection",
              "name": "SQL Injection",
              "shortDescription": {
                "text": "Potential SQL injection vulnerability"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "aws-access-key",
          "level": "error",
          "message": {
            "text": "AWS access key found in config.py:10"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config.py"
                },
                "region": {
                  "startLine": 10,
                  "endLine": 10,
                  "startColumn": 1,
                  "endColumn": 40
                }
              }
            }
          ]
        },
        {
          "ruleId": "sql-injection",
          "level": "error",
          "message": {
            "text": "User input not sanitized in query"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "database.py"
                },
                "region": {
                  "startLine": 25,
                  "endLine": 25,
                  "startColumn": 8,
                  "endColumn": 35
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
